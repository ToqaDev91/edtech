#!/bin/bash
set -o errexit
set -o pipefail
set -o nounset

action=$1
shift

function check_needs_compile() {
    # Find the newest .po file
    newest_po=$(find . -name "*.po" -type f -printf '%T@ %p\n' 2>/dev/null | sort -n | tail -1 | cut -f2- -d" ")
    # Find the oldest .mo file
    oldest_mo=$(find . -name "*.mo" -type f -printf '%T@ %p\n' 2>/dev/null | sort -n | head -1 | cut -f2- -d" ")
    
    if [ -z "$newest_po" ]; then
        # No .po files found
        return 1
    fi
    
    if [ -z "$oldest_mo" ]; then
        # No .mo files found but .po exists
        return 0
    fi
    
    # Compare modification times
    po_time=$(stat -c %Y "$newest_po")
    mo_time=$(stat -c %Y "$oldest_mo")
    
    if [ "$po_time" -gt "$mo_time" ]; then
        return 0  # Needs compile
    else
        return 1  # No compile needed
    fi
}

function setup_initial_data() {
    need_setup=false
    
    # Check if it's first run
    if [ ! -f "/app/.first_run_completed" ]; then
        echo "First run detected. Will run initial setup commands..."
        python manage.py makemigrations
        if python manage.py shell -c "from django.contrib.auth import get_user_model; User = get_user_model(); exit(0 if User.objects.filter(is_superuser=True).exists() else 1)"; then
            echo "Superuser already exists, skipping creation"
        else
            echo "Creating superuser..."
            python manage.py createsuperuser --noinput
        fi
        need_setup=true
    fi
    
    # Check if messages need compilation
    if check_needs_compile; then
        echo "Found .po files that need compilation..."
        python manage.py compilemessages --locale=ar
        need_setup=true
    fi
    
    # Run setup if needed
    if [ "$need_setup" = true ]; then
        echo "Running setup commands..."
        python manage.py collectstatic --noinput
        touch /app/.first_run_completed
        echo "Setup completed."
    else
        echo "No setup needed, skipping setup commands..."
    fi
}

case $action in
    runserver)
        python manage.py migrate
        setup_initial_data
        if [[ "${ENVIROMENT:-local}" == "local" ]]; then
            exec python -m debugpy --listen 0.0.0.0:5678 manage.py runserver 0.0.0.0:8000
        else
            exec python manage.py runserver 0.0.0.0:8000
        fi
        ;;
    gunicorn)
        python manage.py migrate_once
        setup_initial_data
        exec gunicorn --workers=2 --timeout 60 config.wsgi:application -b 0.0.0.0:8000
        ;;
    migrate)
        python manage.py migrate "${@:-}"
        ;;
    makemigrations)
        exec python manage.py makemigrations "${@:-}"
        ;;
    shell)
        exec python manage.py shell_plus
        ;;
    test)
        exec pytest "$@"
        ;;
    celery)
        exec celery -A config.celery worker -l INFO "$@"
        ;;
    celerybeat)
        exec celery -A config.celery beat -l INFO "$@"
        ;;
    flower)
        exec celery -A config.celery flower "$@"
        ;;
    setup)
        setup_initial_data
        ;;
    *)
        exec "$action" "$@"
        ;;
esac